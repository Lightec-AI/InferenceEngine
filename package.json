{
  "name": "@teechat/inference-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TeaChat inference engine — decrypt, vLLM, encrypt (OPE)",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./protocol": {
      "types": "./src/protocol/types.ts",
      "import": "./src/protocol/types.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "import": "./src/testing/index.ts"
    }
  },
  "scripts": {
    "build:ffi": "node scripts/build-ope-ffi.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "koffi": "^2.16.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "~5.7.2",
    "vitest": "^3.1.4"
  }
}
