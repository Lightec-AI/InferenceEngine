{
  "name": "@teechat/inference-engine",
  "version": "0.8.1",
  "private": true,
  "type": "module",
  "description": "TeeChat inference engine — decrypt, vLLM, encrypt (OPE)",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./protocol": {
      "types": "./src/protocol/types.ts",
      "import": "./src/protocol/types.ts"
    },
    "./protocol/ope-stream": {
      "types": "./src/protocol/ope-stream.ts",
      "import": "./src/protocol/ope-stream.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "import": "./src/testing/index.ts"
    },
    "./browser": {
      "types": "./src/browser.ts",
      "import": "./src/browser.ts"
    },
    "./wasm-loader": {
      "types": "./src/native/ope-wasm.ts",
      "import": "./src/native/ope-wasm.ts"
    }
  },
  "bin": {
    "teechat-inference-engine": "./scripts/run-engine.ts"
  },
  "scripts": {
    "start": "node --import tsx scripts/run-engine.ts",
    "start:dist": "node dist/inference-engine.mjs",
    "build": "node scripts/build-runtime.mjs",
    "pack:runtime": "node scripts/pack-runtime.mjs",
    "fetch:ffi": "node scripts/fetch-ope-ffi.mjs",
    "fetch:attested-mtls": "node scripts/fetch-attested-mtls.mjs",
    "build:ffi": "node scripts/build-ope-ffi.mjs",
    "build:wasm": "node scripts/build-ope-wasm.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@teechat/attested-mtls-node": "0.1.0",
    "@teechat/ope-protocol": "file:../ope/packages/ope-protocol",
    "@teechat/ope-wasm": "0.1.0",
    "koffi": "^2.16.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.25.0",
    "typescript": "~5.7.2",
    "vitest": "^3.1.4"
  }
}
